<Window x:Class="EyeVrrf.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Software for EYE-200 VRRF" Height="1020" Width="1680"
        Icon="app_icon.ico"
        MinHeight="760" MinWidth="1180"
        Background="#000000" Foreground="White">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#2e2e2e"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#22c7d6"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#343434"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="BorderBrush" Value="#777777"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#6c6c6c"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#606060"/>
            <Setter Property="VerticalGridLinesBrush" Value="#606060"/>
            <Setter Property="RowBackground" Value="Black"/>
            <Setter Property="AlternatingRowBackground" Value="#050505"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#606060"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="438"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="10,8,10,8">
                <Border Background="{StaticResource PanelBrush}" CornerRadius="4" Padding="14,10" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Sampling Freq."/>
                            <TextBlock Text="(3000 Fixed)" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="3000.0" FontSize="20" Margin="0,0,8,0"/>
                            <TextBlock Text="[Hz]" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource PanelBrush}" CornerRadius="4" Padding="14,10" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Observation Time"/>
                            <TextBlock Text="(0.100 ~ 33.000)" FontSize="14"/>
                        </StackPanel>
                        <TextBox x:Name="ObservationTextBox" Grid.Column="1" Text="10.923" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="[sec]" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Border Background="{StaticResource PanelBrush}" CornerRadius="4" Padding="14,10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Time Window for Trend"/>
                            <TextBlock Text="(0.100 ~ 0.500)" FontSize="14"/>
                        </StackPanel>
                        <TextBox x:Name="TrendWindowTextBox" Grid.Column="1" Text="0.150" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="[sec]" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Serial Port" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PortComboBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sample Count" Margin="0,0,0,4"/>
                        <ComboBox x:Name="SampleCountComboBox" SelectedIndex="9">
                            <ComboBoxItem Content="64"/>
                            <ComboBoxItem Content="128"/>
                            <ComboBoxItem Content="256"/>
                            <ComboBoxItem Content="512"/>
                            <ComboBoxItem Content="1024"/>
                            <ComboBoxItem Content="2048"/>
                            <ComboBoxItem Content="4096"/>
                            <ComboBoxItem Content="8192"/>
                            <ComboBoxItem Content="16384"/>
                            <ComboBoxItem Content="32768"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="RangeSummaryGrid" ItemsSource="{Binding RangeRows}" Height="178" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Range No." Binding="{Binding RangeNo}" Width="95"/>
                        <DataGridTextColumn Header="Start data [sec]" Binding="{Binding StartData}" Width="110"/>
                        <DataGridTextColumn Header="End data [sec]" Binding="{Binding EndData}" Width="110"/>
                        <DataGridTextColumn Header="VRR Flicker Index" Binding="{Binding FlickerIndex}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="RangeTrendGrid" ItemsSource="{Binding RangeRows}" Height="184" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Range No." Binding="{Binding RangeNo}" Width="95"/>
                        <DataGridTextColumn Header="VRRF Trend Max." Binding="{Binding TrendMax}" Width="110"/>
                        <DataGridTextColumn Header="VRRF Trend Min." Binding="{Binding TrendMin}" Width="110"/>
                        <DataGridTextColumn Header="VRRF Trend Ave." Binding="{Binding TrendAve}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button x:Name="SaveRangeButton" Content="Save Range Data" Width="170" HorizontalAlignment="Right" Click="SaveRangeButton_Click"/>
            </StackPanel>

            <Grid Grid.Column="1" Margin="0,8,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="186"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="Black">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="OriginalCheckBox" Content="Original Data" IsChecked="True" Checked="ChartOptionChanged" Unchecked="ChartOptionChanged" Margin="8,0,18,0"/>
                        <Rectangle Width="20" Height="20" Fill="White" Margin="-8,0,6,0"/>
                        <CheckBox x:Name="WeightedCheckBox" Content="Weighted Data" IsChecked="True" Checked="ChartOptionChanged" Unchecked="ChartOptionChanged" Margin="0,0,18,0"/>
                        <Rectangle Width="20" Height="20" Fill="#ff38db" Margin="-8,0,6,0"/>
                        <CheckBox x:Name="TrendCheckBox" Content="VRRF Trend" IsChecked="True" Checked="ChartOptionChanged" Unchecked="ChartOptionChanged"/>
                        <Rectangle Width="20" Height="20" Fill="#26ff4f" Margin="6,0,0,0"/>
                    </StackPanel>
                    <Button x:Name="SaveCsvButton" Grid.Column="1" Content="Save to CSV" Click="SaveCsvButton_Click"/>
                    <Button x:Name="ClearButton" Grid.Column="2" Content="Clear" Click="ClearButton_Click" Margin="8,0,8,0"/>
                </Grid>

                <Border Grid.Row="1" BorderBrush="#333333" BorderThickness="1">
                    <Grid Background="Black">
                        <Canvas x:Name="ChartCanvas" Background="Black"
                                SizeChanged="ChartCanvas_SizeChanged"
                                MouseWheel="ChartCanvas_MouseWheel"
                                MouseLeftButtonDown="ChartCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="ChartCanvas_MouseLeftButtonUp"
                                MouseMove="ChartCanvas_MouseMove">
                            <Canvas.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="ZoomXMenuItem" Header="仅X轴缩放" Click="ZoomXMenuItem_Click"/>
                                    <MenuItem x:Name="ZoomYMenuItem" Header="仅Y轴缩放" Click="ZoomYMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="PanXMenuItem" Header="仅左右拖拽" Click="PanXMenuItem_Click"/>
                                    <MenuItem x:Name="PanYMenuItem" Header="仅上下拖拽" Click="PanYMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="自适应" Click="AutoFitMenuItem_Click"/>
                                </ContextMenu>
                            </Canvas.ContextMenu>
                        </Canvas>
                        <TextBlock Text="Time [sec]" Foreground="#00f0ff" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                        <TextBlock Text="Y(Lv) [cd/m^2]" Foreground="#00f0ff" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                        <TextBlock Text="VRR Flicker Trend[%]" Foreground="#00f0ff" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2" x:Name="HistoryGrid"
                          ItemsSource="{Binding HistoryRows}"
                          Margin="0,10,0,0"
                          SelectionUnit="CellOrRowHeader"
                          SelectionMode="Extended"
                          ClipboardCopyMode="IncludeHeader">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="导出CSV" Click="ExportHistoryCsvMenuItem_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="No." Binding="{Binding Number}" Width="52"/>
                        <DataGridTextColumn Header="Sampling Freq." Binding="{Binding SamplingRate}" Width="128"/>
                        <DataGridTextColumn Header="Observation Time" Binding="{Binding Observation}" Width="128"/>
                        <DataGridTextColumn Header="Time Window for Trend" Binding="{Binding TrendWindow}" Width="128"/>
                        <DataGridTextColumn Header="VRRF Max." Binding="{Binding TrendMax}" Width="120"/>
                        <DataGridTextColumn Header="VRRF Min." Binding="{Binding TrendMin}" Width="120"/>
                        <DataGridTextColumn Header="VRRF Ave." Binding="{Binding TrendAve}" Width="120"/>
                        <DataGridTextColumn Header="Weighted Max." Binding="{Binding WeightedMax}" Width="130"/>
                        <DataGridTextColumn Header="Weighted Min." Binding="{Binding WeightedMin}" Width="130"/>
                        <DataGridTextColumn Header="Weighted Ave." Binding="{Binding WeightedAve}" Width="130"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="110"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Background="#303030">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="430"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Button Content="0-CAL" Width="94" Margin="0,0,8,0"/>
                <Button Content="Settings" Width="94" Margin="0,0,8,0"/>
                <Button Content="Read Data" Width="94" IsEnabled="False"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Color Window" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Text="R :" VerticalAlignment="Center"/>
                <TextBox Text="255" Width="58" Margin="6,0,10,0"/>
                <TextBlock Text="G :" VerticalAlignment="Center"/>
                <TextBox Text="255" Width="58" Margin="6,0,10,0"/>
                <TextBlock Text="B :" VerticalAlignment="Center"/>
                <TextBox Text="255" Width="58" Margin="6,0,10,0"/>
                <ComboBox x:Name="ModeComboBox" Width="180" SelectedIndex="0">
                    <ComboBoxItem Content="Single"/>
                    <ComboBoxItem Content="Continuous"/>
                    <ComboBoxItem Content="Interval"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBox x:Name="IntervalCountTextBox" Text="10" Width="64" Margin="0,0,8,0"/>
                <TextBlock Text="Times" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBox x:Name="IntervalSecondsTextBox" Text="0" Width="64" Margin="0,0,8,0"/>
                <TextBlock Text="sec" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button x:Name="MeasureButton" Content="Measure" Width="150" Height="60" Foreground="#111111" FontSize="18" FontWeight="Bold" Background="#edf5f7" BorderBrush="#55d8ea" Click="MeasureButton_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#151515" BorderBrush="#333333" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center" Margin="12,0" Foreground="#d7d7d7"/>
        </Border>
    </Grid>
</Window>
