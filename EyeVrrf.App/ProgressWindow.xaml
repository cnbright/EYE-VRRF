<Window x:Class="EyeVrrf.App.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Measurement Progress"
        Width="420" Height="150"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#202020"
        Foreground="White">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageText" Text="Preparing measurement..." FontSize="15"/>
        <ProgressBar x:Name="ProgressBar" Grid.Row="2" Height="24" Minimum="0" Maximum="100"/>
    </Grid>
</Window>
